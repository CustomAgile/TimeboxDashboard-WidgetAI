{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Build Widget",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run build",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    },
    {
      "name": "Deploy Widget",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run deploy",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    },
    {
      "name": "Dev Server",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    }
  ]
}
